# Football Data Crawler 环境配置（示例）

# 数据源 API Keys
FOOTBALL_DATA_ORG_API_KEY=your_api_key_here

# 浏览器设置
HEADLESS=true
BROWSER_TIMEOUT=30000
PAGE_LOAD_TIMEOUT=60000

# 采集设置
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
MAX_RETRIES=3
RETRY_DELAY=5

# 路径配置 (统一数据根目录: D:/FootballData)
DATA_ROOT=D:/FootballData
OUTPUT_DIR=D:/FootballData/exports
RAW_DATA_DIR=D:/FootballData/raw_data
CLEAN_DATA_DIR=D:/FootballData/raw_data
DATABASE_DIR=D:/FootballData/database
SNAPSHOTS_DIR=D:/FootballData/snapshots
MODELS_DIR=D:/FootballData/models
LOG_DIR=crawler/logs
CACHE_DIR=crawler/cache

# Web UI
UI_HOST=127.0.0.1
UI_PORT=8080

# 日志级别
LOG_LEVEL=INFO

# PostgreSQL 数据库
# 方式一：完整连接字符串
DATABASE_URL=
# 方式二：逐个字段配置（DATABASE_URL 优先级更高）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_crawler
DB_USER=postgres
DB_PASSWORD=your_password_here
