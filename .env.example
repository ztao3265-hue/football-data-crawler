# Football Data Crawler 环境配置（示例）

# 数据源 API Keys
FOOTBALL_DATA_ORG_API_KEY=your_api_key_here

# 浏览器设置
HEADLESS=true
BROWSER_TIMEOUT=30000
PAGE_LOAD_TIMEOUT=60000

# 采集设置
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
MAX_RETRIES=3
RETRY_DELAY=5

# 路径配置
OUTPUT_DIR=exports
LOG_DIR=crawler/logs
CACHE_DIR=crawler/cache
RAW_DATA_DIR=data/raw
CLEAN_DATA_DIR=data/clean

# Web UI
UI_HOST=127.0.0.1
UI_PORT=8080

# 日志级别
LOG_LEVEL=INFO
