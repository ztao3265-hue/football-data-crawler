# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
.pytest_cache/
.coverage
.python-version
*.pyc

# ── IDE ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn

# ── 环境变量 / 密钥 ─────────────────────────────────────
.env
.env.local
.env.*
*.pem
*.key
credentials.json
secrets.json

# ── SQLite ──────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ── 数据输出 (生成文件, 不提交) ──────────────────────────
exports/*.json
exports/*.csv
exports/*.xlsx
data/raw/*
datasets/*
models/*
data/clean/*
data/processed/*
data/reports/*
!data/raw/.gitkeep
!data/clean/.gitkeep

# ── 统一数据目录 (D:/FootballData) ────────────────────────
# 所有数据文件已迁移到 D:/FootballData，该目录完全由外部管理

# ── 日志 ────────────────────────────────────────────────
*.log
!crawler/logs/.gitkeep

# ── 缓存 ────────────────────────────────────────────────
crawler/cache/*
!crawler/cache/.gitkeep
__pycache__/

# ── 截图和输出 ──────────────────────────────────────────
crawler/output/screenshots/*
!crawler/output/screenshots/.gitkeep
crawler/output/*

# ── 浏览器自动化 ────────────────────────────────────────
browser_data/
playwright-report/
test-results/
catboost_info/

# ── 审计大文件 (交易明细 CSV 通常 > 1MB) ─────────────────
reports/backtest/audit/trade_audit_*.csv
reports/asian_microstructure/*.csv

# ── 临时文件 ────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*~
*.orig

# ── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Docker ──────────────────────────────────────────────
.docker/

# ── Node (如果有前端) ───────────────────────────────────
node_modules/
.next/
.nuxt/
dist-frontend/

# ── OS ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
